# ============================================================
# API Keys
# ============================================================

# API-Football (https://www.api-football.com/ 或 RapidAPI)
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (备用 fallback，https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ============================================================
# 数据库 & 存储
# ============================================================

# SQLite 路径，可以指向移动硬盘，例如:
# DB_PATH=/Volumes/MyDisk/football_data/football.db
DB_PATH=./data/football.db

# 爬虫缓存目录（同样可以指向移动硬盘）
CACHE_DIR=./data/cache

# ============================================================
# 行为配置
# ============================================================

# API-Football 每日请求上限（免费层100，付费层300+）
API_DAILY_LIMIT=100

# 日志级别: DEBUG / INFO / WARNING
LOG_LEVEL=INFO

# 预测目标联赛（逗号分隔的 API-Football league_id）
# 39=英超, 140=西甲, 78=德甲, 135=意甲, 61=法甲, 169=中超
TARGET_LEAGUES=39,140,78,135,61,169
